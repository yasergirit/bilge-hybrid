# Resend API Key — get yours at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Email sender — use your verified domain or resend.dev for testing
FROM_EMAIL=onboarding@resend.dev

# Verification token secret — change in production
VERIFICATION_SECRET=your-secret-key-here

# App URL — update for production
NEXT_PUBLIC_APP_URL=https://bilge-hybrid.vercel.app
